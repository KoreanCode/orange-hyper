{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.js",
    "scripts/**/*.js",
    "src/**/*.js",
    "src/**/*.d.ts",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    ".orange-hyper",
    "dist",
    "build"
  ]
}
